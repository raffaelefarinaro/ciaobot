# --- Ciao Server (required) ---
PWA_AUTH_TOKEN=                # Pre-shared token for PWA auth (required)
CIAO_PUSH_CONTACT=mailto:you@example.com # Required VAPID contact for push notifications

# --- Ciao Server (optional) ---
PWA_PORT=8443                  # PWA server port (default: 8443)
PWA_HOST=0.0.0.0               # PWA server host (default: 0.0.0.0)
CIAO_WORKSPACE=.               # Operational workspace root (default: current dir)
CIAO_VAULT_ROOT=memory-vault   # Vault root (default: CIAO_WORKSPACE/memory-vault)
CIAO_RUNTIME_ROOT=.runtime     # Runtime state dir (default: .runtime)
CIAO_RESTART_EXIT_CODE=75      # Exit code that triggers restart loop (default: 75)
CIAO_AUTO_SYNC_ON_START=true   # Auto git pull --rebase on startup (default: true)
CIAO_AUTO_VAULT_INDEX=true     # Regenerate INDEX.md on startup (default: true)

# --- Provider and model routing (optional) ---
CLAUDE_EXECUTION_MODE=auto     # normal | plan | auto | bypass
CLAUDE_MODELS=opus,sonnet,haiku # Models shown in the picker
CIAO_TITLE_MODEL=haiku         # Chat auto-title model
# ANTHROPIC_API_KEY=           # Optional fallback when not using provider OAuth

# --- Ollama routing (optional) ---
# CIAO_OLLAMA_MODELS=kimi-k2.7-code:cloud,deepseek-v4-flash:cloud
# CIAO_OLLAMA_LOCAL_MODELS=llama3.2
# CIAO_OLLAMA_API_KEY=         # Ollama Cloud API key
# CIAO_OLLAMA_URL=             # Base URL override
# CIAO_OLLAMA_LOCAL_URL=http://localhost:11434
# CIAO_OLLAMA_TITLE_MODEL=
# CIAO_OLLAMA_HAIKU_MODEL=
# CIAO_OLLAMA_SONNET_MODEL=
# CIAO_OLLAMA_OPUS_MODEL=

# --- Pi provider (optional) ---
# CIAO_PI_MODELS=
# CIAO_PI_SESSION_DIR=

# --- Insights and local memory helpers (optional) ---
# CIAO_INSIGHTS_DISABLED=false
# CIAO_INSIGHTS_MIN_TURNS=5
# CIAO_INSIGHTS_MODEL=
# CIAO_TRAJECTORIES_DISABLED=false
# CIAO_TRAJECTORY_RETENTION_MONTHS=6
# CIAO_SKILL_EVOLUTION_DISABLED=false
# CIAO_SKILL_EVOLUTION_MODEL=

# --- File viewer / workspace roots (optional) ---
# CIAO_WORKSPACE_REPOS=~/repos
# CIAO_WORKSPACE_EXTRA_ROOTS=~/.claude

# --- Media upload limits (optional) ---
# CIAO_MAX_IMAGE_BYTES=10485760
# CIAO_MAX_VOICE_BYTES=26214400
# CIAO_MEDIA_TTL_HOURS=72

# --- Push notifications (optional) ---
# CIAO_PUSH_DELAY_SECONDS=30

# --- OpenAI (optional) ---
# OPENAI_API_KEY=              # Used by voice transcription and other OpenAI features

# --- Voice transcription (optional) ---
# CIAO_TRANSCRIPTION_ENGINE=cloud
# CIAO_TRANSCRIPTION_LOCAL_MODEL=mlx-community/whisper-large-v3-turbo

# --- Remote PWA proxy (optional) ---
# REMOTE_PWA_URL=
# REMOTE_PWA_TOKEN=

# --- Legacy aliases (still accepted but deprecated) ---
# CLAUDE_PERMISSION_MODE=auto
# TELEGRAM_BRIDGE_WORKSPACE=.
# TELEGRAM_BRIDGE_RUNTIME_ROOT=.runtime
# TELEGRAM_BRIDGE_AUTO_SYNC_ON_START=true
# TELEGRAM_BRIDGE_MAX_IMAGE_BYTES=10485760
# TELEGRAM_BRIDGE_MAX_VOICE_BYTES=26214400
# TELEGRAM_BRIDGE_MEDIA_TTL_HOURS=72
# TELEGRAM_BRIDGE_RESTART_EXIT_CODE=75
