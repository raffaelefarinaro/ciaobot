# Python bytecode and caches
__pycache__/
*.py[cod]

# Editable install metadata
*.egg-info/

# Virtualenvs
.venv/
venv/

# Frontend dependencies
web/node_modules/

# Frontend build output (regenerated by `npm run build` and the Deploy flow;
# vite outDir is ciao/web/static, hashed bundles land in assets/)
ciao/web/static/assets/

# Python build artifacts
build/
dist/

# Local runtime / package-smoke artifacts (the live runtime lives in the
# operator repo, not here)
.runtime/

# OS noise
.DS_Store
# Private memory vault data must never be committed to the app repo
memory-vault/

# Claude Code session tooling (worktrees, local permission grants)
.claude/
